# .env — ローカル設定(API キー等)。このファイルを .env にコピーして使う。
# .env は .gitignore 済みなのでコミットされない(鍵を安全に置ける)。
#   PowerShell 例:  Copy-Item .env.example .env   その後 .env を編集
#
# 既存の環境変数(setx など)があればそちらが優先される。
# .env なら Windows の環境変数伝播(既存窓・ダブルクリックに反映されない問題)を回避できる。

# OpenAI を既定エンジンにして鍵を渡す例:
LRAC_TTS_ENGINE=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 任意:
# LRAC_OPENAI_VOICE=alloy            # 手動コピー等(マーカー無し)の既定声
# LRAC_OPENAI_INSTRUCTIONS=落ち着いた低めの声で、句読点でしっかり間を取って
# LRAC_OPENAI_TTS_MODEL=gpt-4o-mini-tts
# LRAC_OPENAI_SPEED=1.5              # 話速 0.25〜4.0

# 会話スレッドごとに声を変える(既定で有効)。
# 分ける単位: project(既定=作業フォルダ単位・再開や複数セッションでも安定) | session(セッション単位)
# LRAC_THREAD_KEY=project
# LRAC_OPENAI_VOICE_POOL=ash,ballad,coral,sage,verse,onyx
# LRAC_THREAD_VOICE=0               # スレッド別音声を無効化(マーカーを付けない)

# 英語の行(日本語がほぼ無く英字主体)を「そもそもクリップボードにコピーしない」。
# コピー側(Stop フック/監視)で除外するので、英文は載らない=読まれない:
# LRAC_SKIP_ENGLISH=1
# LRAC_SKIP_ENGLISH_MINLATIN=12     # 英語と判定する英字数の下限

# AivisSpeech(ローカル)を使う場合は engine を切り替え(鍵不要):
# LRAC_TTS_ENGINE=aivis
# LRAC_AIVIS_SPEAKER=888753760
